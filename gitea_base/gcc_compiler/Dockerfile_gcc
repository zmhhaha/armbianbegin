# 下载环境配置
FROM base:latest AS builder-env

# 设置环境变量
ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Etc/UTC

RUN apt-get update && apt-get install -y \
    build-essential \
    make \
    cmake \
    ninja-build \
    gcc \
    g++ \
    libstdc++6 \
    libgcc-s1 \
    gcc-aarch64-linux-gnu \
    g++-aarch64-linux-gnu \
    binutils-aarch64-linux-gnu \
    libc6-dev-arm64-cross \
    file \
    pkg-config \
    git \
    wget \
    curl \
    python3 \
    python3-pip \
    cppcheck \
    flex \
    bison \
    && rm -rf /var/lib/apt/lists/*

RUN mkdir -p /opt/toolchains
COPY arm64.cmake /opt/toolchains/arm64.cmake
COPY x86_64.cmake /opt/toolchains/x86_64.cmake

# 创建非 root 用户
RUN groupadd -g 1000 builder && \
    useradd -m -u 1000 -g builder builder

# 设置工作目录
WORKDIR /workspace
RUN chown builder:builder /workspace

# 切换到非 root 用户
USER builder

# 验证安装
RUN ls && \ 
    gcc --version && \
    cmake --version

# 设置入口点
ENTRYPOINT ["/bin/bash"]