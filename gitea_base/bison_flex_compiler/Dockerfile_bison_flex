#docker build -f Dockerfile_bison_flex -t bison_flex_compiler:latest .

# 下载环境配置
FROM base:latest AS builder-env
 
# 安装编译工具链（gcc, make, cmake）和 Flex/Bison
RUN apt-get update && apt-get install -y \
    flex \
    bison \
    build-essential \
    cmake \
    git \
    && rm -rf /var/lib/apt/lists/*
 
# 设置工作目录
WORKDIR /workspace
 
# 默认命令（可选）
CMD ["/bin/bash"]